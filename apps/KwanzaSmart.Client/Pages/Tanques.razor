@page "/tanques"

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
                Tanques
            </h1>
            <p class="text-gray-500 text-sm mt-1 flex items-center gap-2">
                <i class="fa-solid fa-water text-cyan-500 text-[10px]"></i>
                Gestão e monitorização dos tanques de aquicultura
            </p>
        </div>
        <div class="flex gap-2">
            <button class="bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-500 hover:to-blue-600 text-white rounded-xl px-5 py-2.5 text-sm font-medium transition-all flex items-center gap-2 shadow-lg shadow-blue-600/20">
                <i class="fa-solid fa-plus"></i> Novo Tanque
            </button>
        </div>
    </div>

    <!-- Visão Geral dos Tanques -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Tanque 1 - Principal -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-fish text-blue-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Tanque Principal</h3>
                        <p class="text-gray-500 text-xs">Capacidade: 5.000 L</p>
                    </div>
                </div>
                <span class="text-green-400 text-xs bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20">Ativo</span>
            </div>
            
            <!-- Sensores do Tanque -->
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🌡️ Temperatura</p>
                    <p class="text-white text-sm font-semibold">28.5°C</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🧪 pH</p>
                    <p class="text-white text-sm font-semibold">7.2</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💨 Oxigénio</p>
                    <p class="text-white text-sm font-semibold">6.2 mg/L</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💧 Nível</p>
                    <p class="text-white text-sm font-semibold">65%</p>
                </div>
            </div>
            
            <div class="flex justify-between items-center mt-4 pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Última leitura: 16:20</span>
                <button class="text-blue-400 text-xs hover:text-blue-300 transition-colors">Ver detalhes →</button>
            </div>
        </div>

        <!-- Tanque 2 - Secundário -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-fish-fins text-cyan-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Tanque Secundário</h3>
                        <p class="text-gray-500 text-xs">Capacidade: 2.500 L</p>
                    </div>
                </div>
                <span class="text-green-400 text-xs bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20">Ativo</span>
            </div>
            
            <!-- Sensores do Tanque -->
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🌡️ Temperatura</p>
                    <p class="text-white text-sm font-semibold">27.8°C</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🧪 pH</p>
                    <p class="text-white text-sm font-semibold">7.0</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💨 Oxigénio</p>
                    <p class="text-white text-sm font-semibold">6.8 mg/L</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💧 Nível</p>
                    <p class="text-white text-sm font-semibold">78%</p>
                </div>
            </div>
            
            <div class="flex justify-between items-center mt-4 pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Última leitura: 16:15</span>
                <button class="text-blue-400 text-xs hover:text-blue-300 transition-colors">Ver detalhes →</button>
            </div>
        </div>

        <!-- Tanque 3 - Quarentena -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-yellow-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-shield-heart text-yellow-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Tanque Quarentena</h3>
                        <p class="text-gray-500 text-xs">Capacidade: 1.000 L</p>
                    </div>
                </div>
                <span class="text-yellow-400 text-xs bg-yellow-500/10 px-2 py-0.5 rounded-full border border-yellow-500/20">Manutenção</span>
            </div>
            
            <!-- Sensores do Tanque -->
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🌡️ Temperatura</p>
                    <p class="text-white text-sm font-semibold">26.5°C</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🧪 pH</p>
                    <p class="text-white text-sm font-semibold">6.8</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💨 Oxigénio</p>
                    <p class="text-white text-sm font-semibold">7.2 mg/L</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💧 Nível</p>
                    <p class="text-white text-sm font-semibold">55%</p>
                </div>
            </div>
            
            <div class="flex justify-between items-center mt-4 pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Última leitura: 15:50</span>
                <button class="text-blue-400 text-xs hover:text-blue-300 transition-colors">Ver detalhes →</button>
            </div>
        </div>

        <!-- Tanque 4 - Alevinos -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-egg text-green-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Tanque Alevinos</h3>
                        <p class="text-gray-500 text-xs">Capacidade: 800 L</p>
                    </div>
                </div>
                <span class="text-green-400 text-xs bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20">Ativo</span>
            </div>
            
            <!-- Sensores do Tanque -->
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🌡️ Temperatura</p>
                    <p class="text-white text-sm font-semibold">29.0°C</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">🧪 pH</p>
                    <p class="text-white text-sm font-semibold">7.4</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💨 Oxigénio</p>
                    <p class="text-white text-sm font-semibold">5.8 mg/L</p>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-2 text-center">
                    <p class="text-gray-500 text-[10px]">💧 Nível</p>
                    <p class="text-white text-sm font-semibold">70%</p>
                </div>
            </div>
            
            <div class="flex justify-between items-center mt-4 pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Última leitura: 16:05</span>
                <button class="text-blue-400 text-xs hover:text-blue-300 transition-colors">Ver detalhes →</button>
            </div>
        </div>
    </div>

    <!-- População por Tanque -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700">
        <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
            <div class="w-1 h-6 bg-cyan-500 rounded-full"></div>
            <i class="fa-solid fa-chart-pie text-cyan-500"></i>
            População por Tanque
        </h3>
        <div class="space-y-3">
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span class="text-gray-400">Tanque Principal</span>
                    <span class="text-white font-medium">1.200 peixes</span>
                </div>
                <div class="w-full bg-gray-800 rounded-full h-2">
                    <div class="bg-blue-500 h-2 rounded-full" style="width: 60%"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span class="text-gray-400">Tanque Secundário</span>
                    <span class="text-white font-medium">600 peixes</span>
                </div>
                <div class="w-full bg-gray-800 rounded-full h-2">
                    <div class="bg-cyan-500 h-2 rounded-full" style="width: 30%"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span class="text-gray-400">Tanque Quarentena</span>
                    <span class="text-white font-medium">50 peixes</span>
                </div>
                <div class="w-full bg-gray-800 rounded-full h-2">
                    <div class="bg-yellow-500 h-2 rounded-full" style="width: 5%"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1">
                    <span class="text-gray-400">Tanque Alevinos</span>
                    <span class="text-white font-medium">800 peixes</span>
                </div>
                <div class="w-full bg-gray-800 rounded-full h-2">
                    <div class="bg-green-500 h-2 rounded-full" style="width: 40%"></div>
                </div>
            </div>
            <div class="pt-2 border-t border-gray-800">
                <div class="flex justify-between text-sm font-semibold">
                    <span class="text-gray-300">Total</span>
                    <span class="text-white">2.650 peixes</span>
                </div>
            </div>
        </div>
    </div>
</div>