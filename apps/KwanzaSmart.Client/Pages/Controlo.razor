@page "/controlo"

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
                Controlo
            </h1>
            <p class="text-gray-500 text-sm mt-1 flex items-center gap-2">
                <i class="fa-solid fa-sliders-h text-blue-500 text-[10px]"></i>
                Controlo manual e automático dos equipamentos
            </p>
        </div>
        <div class="flex gap-2">
            <div class="bg-gray-800/50 rounded-full px-4 py-2 flex items-center gap-2">
                <span class="text-xs text-gray-400">Modo atual:</span>
                <span class="text-xs font-semibold text-green-400 flex items-center gap-1">
                    <i class="fa-solid fa-circle text-[6px]"></i> Automático
                </span>
            </div>
        </div>
    </div>

    <!-- Cards de Controlo -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Bomba de Água -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-water-pump text-blue-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Bomba de Água</h3>
                        <p class="text-gray-500 text-xs">Circulação e oxigenação</p>
                    </div>
                </div>
                <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                    <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
                </div>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Status:</span>
                <span class="text-green-400 text-xs font-medium flex items-center gap-1">
                    <i class="fa-solid fa-circle text-[6px]"></i> Ligada
                </span>
            </div>
        </div>

        <!-- Aerador -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-fan text-cyan-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Aerador</h3>
                        <p class="text-gray-500 text-xs">Oxigenação da água</p>
                    </div>
                </div>
                <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                    <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
                </div>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Status:</span>
                <span class="text-yellow-400 text-xs font-medium flex items-center gap-1">
                    <i class="fa-solid fa-circle text-[6px]"></i> Desligada
                </span>
            </div>
        </div>

        <!-- Aquecedor -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-temperature-high text-red-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Aquecedor</h3>
                        <p class="text-gray-500 text-xs">Aquecimento da água</p>
                    </div>
                </div>
                <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                    <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
                </div>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Status:</span>
                <span class="text-gray-500 text-xs font-medium">Auto (22°C)</span>
            </div>
        </div>

        <!-- Alimentador -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-orange-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-bowl-food text-orange-400 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-semibold">Alimentador</h3>
                        <p class="text-gray-500 text-xs">Ração automática</p>
                    </div>
                </div>
                <button class="bg-orange-500/20 hover:bg-orange-500/30 text-orange-400 text-xs font-medium px-3 py-1.5 rounded-full transition-all">
                    Alimentar agora
                </button>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-gray-800">
                <span class="text-gray-500 text-xs">Próxima alimentação:</span>
                <span class="text-gray-300 text-xs">18:00</span>
            </div>
        </div>
    </div>

    <!-- Modo de Operação -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700">
        <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
            <div class="w-1 h-6 bg-purple-500 rounded-full"></div>
            <i class="fa-solid fa-gear text-purple-500"></i>
            Modo de Operação
        </h3>
        <div class="flex flex-wrap gap-4">
            <button class="flex-1 bg-green-500/20 border border-green-500/50 text-green-400 rounded-xl py-3 px-4 font-semibold hover:bg-green-500/30 transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-robot"></i> Automático
            </button>
            <button class="flex-1 bg-gray-800 hover:bg-gray-700 text-gray-400 rounded-xl py-3 px-4 font-semibold transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-hand"></i> Manual
            </button>
        </div>
        <p class="text-gray-500 text-xs mt-4 text-center">
            No modo automático, o sistema liga/desliga equipamentos com base nos sensores
        </p>
    </div>

    <!-- Comandos Recentes -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700">
        <div class="flex justify-between items-center mb-4">
            <h3 class="font-semibold text-white flex items-center gap-2">
                <div class="w-1 h-6 bg-blue-500 rounded-full"></div>
                <i class="fa-solid fa-clock-rotate-left text-blue-500"></i>
                Comandos Recentes
            </h3>
            <button class="text-blue-400 text-xs hover:text-blue-300 transition-colors">Ver histórico</button>
        </div>
        <div class="space-y-2">
            <div class="flex items-center justify-between py-2 border-b border-gray-800">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-water-pump text-blue-400 text-sm"></i>
                    <span class="text-gray-300 text-sm">Bomba ligada</span>
                </div>
                <span class="text-gray-500 text-xs">Automático • Há 5 min</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-800">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-bowl-food text-orange-400 text-sm"></i>
                    <span class="text-gray-300 text-sm">Alimentador acionado</span>
                </div>
                <span class="text-gray-500 text-xs">Manual • Há 15 min</span>
            </div>
            <div class="flex items-center justify-between py-2">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-fan text-cyan-400 text-sm"></i>
                    <span class="text-gray-300 text-sm">Aerador desligado</span>
                </div>
                <span class="text-gray-500 text-xs">Automático • Há 1 hora</span>
            </div>
        </div>
    </div>
</div>