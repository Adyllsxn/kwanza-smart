@page "/alertas"

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
                Alertas
            </h1>
            <p class="text-gray-500 text-sm mt-1 flex items-center gap-2">
                <i class="fa-solid fa-bell text-yellow-500 text-[10px]"></i>
                Histórico de alertas do sistema
            </p>
        </div>
        <div class="flex gap-2">
            <button class="bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-500 hover:to-blue-600 text-white rounded-xl px-5 py-2.5 text-sm font-medium transition-all flex items-center gap-2 shadow-lg shadow-blue-600/20">
                <i class="fa-solid fa-check-double"></i> Marcar todos como lidos
            </button>
            <button class="bg-gray-800 hover:bg-gray-700 text-white rounded-xl px-5 py-2.5 text-sm font-medium transition-all flex items-center gap-2">
                <i class="fa-solid fa-rotate"></i> Atualizar
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="flex flex-wrap gap-2">
        <button class="bg-blue-600 text-white rounded-full px-4 py-1.5 text-xs font-medium transition-all">Todos</button>
        <button class="bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-full px-4 py-1.5 text-xs font-medium transition-all">Não lidos</button>
        <button class="bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-full px-4 py-1.5 text-xs font-medium transition-all">Temperatura</button>
        <button class="bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-full px-4 py-1.5 text-xs font-medium transition-all">pH</button>
        <button class="bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-full px-4 py-1.5 text-xs font-medium transition-all">Oxigénio</button>
        <button class="bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-full px-4 py-1.5 text-xs font-medium transition-all">Nível</button>
    </div>

    <!-- Alertas Cards -->
    <div class="space-y-3">
        <!-- Alerta Vermelho (Crítico) -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 border-l-4 border-red-500 hover:bg-red-500/5 transition-all duration-300 cursor-pointer">
            <div class="flex items-start justify-between">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-temperature-high text-red-400 text-lg"></i>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-red-400 text-sm font-semibold">⚠️ Temperatura elevada</span>
                            <span class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full">Crítico</span>
                            <span class="text-[10px] text-gray-500">Não lido</span>
                        </div>
                        <p class="text-gray-300 text-sm">A temperatura da água atingiu 32°C, acima do limite recomendado de 28°C.</p>
                        <div class="flex items-center gap-3 mt-2">
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-clock"></i> Há 2 minutos
                            </span>
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-flask"></i> Sensor #1
                            </span>
                        </div>
                    </div>
                </div>
                <button class="text-gray-500 hover:text-green-400 transition-colors">
                    <i class="fa-regular fa-circle-check text-lg"></i>
                </button>
            </div>
        </div>

        <!-- Alerta Amarelo (Atenção) -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 border-l-4 border-yellow-500 hover:bg-yellow-500/5 transition-all duration-300 cursor-pointer">
            <div class="flex items-start justify-between">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-yellow-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-wind text-yellow-400 text-lg"></i>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-yellow-400 text-sm font-semibold">⚠️ Oxigénio baixo</span>
                            <span class="text-[10px] bg-yellow-500/20 text-yellow-400 px-2 py-0.5 rounded-full">Atenção</span>
                            <span class="text-[10px] text-gray-500">Não lido</span>
                        </div>
                        <p class="text-gray-300 text-sm">O nível de oxigénio dissolvido está em 4.8 mg/L. O mínimo recomendado é 5.0 mg/L.</p>
                        <div class="flex items-center gap-3 mt-2">
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-clock"></i> Há 5 minutos
                            </span>
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-flask"></i> Sensor #3
                            </span>
                        </div>
                    </div>
                </div>
                <button class="text-gray-500 hover:text-green-400 transition-colors">
                    <i class="fa-regular fa-circle-check text-lg"></i>
                </button>
            </div>
        </div>

        <!-- Alerta Verde (Resolvido/Lido) -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 border-l-4 border-green-500 opacity-70">
            <div class="flex items-start justify-between">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-circle-check text-green-400 text-lg"></i>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-green-400 text-sm font-semibold">✓ Temperatura normalizada</span>
                            <span class="text-[10px] bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">Resolvido</span>
                            <span class="text-[10px] text-gray-500">Lido</span>
                        </div>
                        <p class="text-gray-400 text-sm">A temperatura voltou aos níveis normais (26.5°C).</p>
                        <div class="flex items-center gap-3 mt-2">
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-clock"></i> Há 10 minutos
                            </span>
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-flask"></i> Sensor #1
                            </span>
                        </div>
                    </div>
                </div>
                <button class="text-green-400 transition-colors" disabled>
                    <i class="fa-solid fa-circle-check text-lg"></i>
                </button>
            </div>
        </div>

        <!-- Outro Alerta -->
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 border-l-4 border-red-500 hover:bg-red-500/5 transition-all duration-300 cursor-pointer">
            <div class="flex items-start justify-between">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center">
                        <i class="fa-solid fa-water text-red-400 text-lg"></i>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-red-400 text-sm font-semibold">⚠️ Nível da água baixo</span>
                            <span class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full">Crítico</span>
                            <span class="text-[10px] text-gray-500">Não lido</span>
                        </div>
                        <p class="text-gray-300 text-sm">O nível da água está em 28%, abaixo do mínimo recomendado de 50%.</p>
                        <div class="flex items-center gap-3 mt-2">
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-clock"></i> Há 15 minutos
                            </span>
                            <span class="text-gray-500 text-xs flex items-center gap-1">
                                <i class="fa-regular fa-flask"></i> Sensor #4
                            </span>
                        </div>
                    </div>
                </div>
                <button class="text-gray-500 hover:text-green-400 transition-colors">
                    <i class="fa-regular fa-circle-check text-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Estatísticas -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-2">
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 text-center border border-gray-700">
            <p class="text-2xl font-bold text-white">12</p>
            <p class="text-gray-500 text-xs">Total de alertas</p>
        </div>
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 text-center border border-gray-700">
            <p class="text-2xl font-bold text-red-400">3</p>
            <p class="text-gray-500 text-xs">Críticos não lidos</p>
        </div>
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 text-center border border-gray-700">
            <p class="text-2xl font-bold text-yellow-400">2</p>
            <p class="text-gray-500 text-xs">Atenção</p>
        </div>
        <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-2xl p-4 text-center border border-gray-700">
            <p class="text-2xl font-bold text-green-400">7</p>
            <p class="text-gray-500 text-xs">Resolvidos</p>
        </div>
    </div>
</div>