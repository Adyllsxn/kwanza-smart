<aside class="@($"fixed top-0 left-0 z-40 h-screen transition-all duration-300 bg-gradient-to-b from-gray-900 to-gray-950 border-r border-gray-800/50 {(IsCollapsed ? "w-20" : "w-64")}")">
    <div class="h-full flex flex-col">
        
        <!-- Header com Logo e Botão Hambúrguer no mesmo nível -->
        <div class="flex items-center justify-between p-6 mt-1">
            <!-- Logo -->
            <a href="/kwanza-smart/" class="transition-transform hover:scale-105 duration-300">
                @if (!IsCollapsed)
                {
                    <img src="assets/logo.svg" alt="KwanzaSmart" class="w-32 h-18" />
                }
                else
                {
                    <img src="assets/logo.svg" alt="KwanzaSmart" class="w-8 h-8" />
                }
            </a>
            
            <!-- Botão Hambúrguer -->
            <button @onclick="OnToggle" class="text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg p-2 transition-all duration-300 focus:outline-none">
                <i class="fa-solid fa-bars text-xl"></i>
            </button>
        </div>

        <!-- Menu -->
        <nav class="flex-1 px-3 mt-8 space-y-1">
            <NavLink href="/kwanza-smart/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200 group" ActiveClass="!bg-blue-600/20 !text-blue-500">
                <i class="fa-solid fa-chart-line w-5 text-lg group-hover:scale-110 transition-transform"></i>
                @if (!IsCollapsed) { <span class="text-sm font-medium">Dashboard</span> }
            </NavLink>
            
            <NavLink href="/kwanza-smart/tanques" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200 group" ActiveClass="!bg-blue-600/20 !text-blue-500">
                <i class="fa-solid fa-water w-5 text-lg group-hover:scale-110 transition-transform"></i>
                @if (!IsCollapsed) { <span class="text-sm font-medium">Tanques</span> }
            </NavLink>
            
            <NavLink href="/kwanza-smart/alertas" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200 group" ActiveClass="!bg-blue-600/20 !text-blue-500">
                <i class="fa-solid fa-bell w-5 text-lg group-hover:scale-110 transition-transform"></i>
                @if (!IsCollapsed) 
                { 
                    <span class="text-sm font-medium">Alertas</span>
                    <span class="ml-auto bg-red-500 text-white text-xs px-1.5 py-0.5 rounded-full">3</span>
                }
            </NavLink>
            
            <NavLink href="/kwanza-smart/historico" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200 group" ActiveClass="!bg-blue-600/20 !text-blue-500">
                <i class="fa-solid fa-clock-rotate-left w-5 text-lg group-hover:scale-110 transition-transform"></i>
                @if (!IsCollapsed) { <span class="text-sm font-medium">Histórico</span> }
            </NavLink>
            
            <NavLink href="/kwanza-smart/controlo" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200 group" ActiveClass="!bg-blue-600/20 !text-blue-500">
                <i class="fa-solid fa-sliders-h w-5 text-lg group-hover:scale-110 transition-transform"></i>
                @if (!IsCollapsed) { <span class="text-sm font-medium">Controlo</span> }
            </NavLink>
        </nav>

        <!-- Footer -->
        <div class="px-3 py-4 border-t border-gray-800/50">
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                @if (!IsCollapsed)
                {
                    <span class="text-xs text-gray-400">Online</span>
                }
            </div>
        </div>
    </div>
</aside>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }
}