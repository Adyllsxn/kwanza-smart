<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Bomba de Água -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-water-pump text-blue-400 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-white font-semibold">Bomba de Água</h3>
                    <p class="text-gray-500 text-xs">Circulação e oxigenação</p>
                </div>
            </div>
            <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
            </div>
        </div>
        <div class="flex justify-between items-center pt-3 border-t border-gray-800">
            <span class="text-gray-500 text-xs">Status:</span>
            <span class="text-green-400 text-xs font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle text-[6px]"></i> Ligada
            </span>
        </div>
    </div>

    <!-- Aerador -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-fan text-cyan-400 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-white font-semibold">Aerador</h3>
                    <p class="text-gray-500 text-xs">Oxigenação da água</p>
                </div>
            </div>
            <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
            </div>
        </div>
        <div class="flex justify-between items-center pt-3 border-t border-gray-800">
            <span class="text-gray-500 text-xs">Status:</span>
            <span class="text-yellow-400 text-xs font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle text-[6px]"></i> Desligada
            </span>
        </div>
    </div>

    <!-- Aquecedor -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-temperature-high text-red-400 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-white font-semibold">Aquecedor</h3>
                    <p class="text-gray-500 text-xs">Aquecimento da água</p>
                </div>
            </div>
            <div class="relative inline-block w-12 h-6 rounded-full bg-gray-700 shadow-inner cursor-pointer">
                <div class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-gray-400 transition-all duration-300"></div>
            </div>
        </div>
        <div class="flex justify-between items-center pt-3 border-t border-gray-800">
            <span class="text-gray-500 text-xs">Status:</span>
            <span class="text-gray-500 text-xs font-medium">Auto (22°C)</span>
        </div>
    </div>

    <!-- Alimentador -->
    <div class="bg-gradient-to-br from-gray-900/80 to-gray-900/40 rounded-3xl p-5 border border-gray-700 hover:border-blue-500/30 transition-all duration-300">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-orange-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-bowl-food text-orange-400 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-white font-semibold">Alimentador</h3>
                    <p class="text-gray-500 text-xs">Ração automática</p>
                </div>
            </div>
            <button class="bg-orange-500/20 hover:bg-orange-500/30 text-orange-400 text-xs font-medium px-3 py-1.5 rounded-full transition-all">
                Alimentar agora
            </button>
        </div>
        <div class="flex justify-between items-center pt-3 border-t border-gray-800">
            <span class="text-gray-500 text-xs">Próxima alimentação:</span>
            <span class="text-gray-300 text-xs">18:00</span>
        </div>
    </div>
</div>